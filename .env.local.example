# Firebase client config (Project Settings > General > Your apps > Web app)
# These are public — safe to expose in the browser bundle.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# The only email allowed to use /admin (defense in depth on top of security rules)
NEXT_PUBLIC_ADMIN_EMAIL=

# Firebase Admin SDK service account (Project Settings > Service accounts > Generate new private key)
# These are SECRET — never commit, never expose to the browser.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
