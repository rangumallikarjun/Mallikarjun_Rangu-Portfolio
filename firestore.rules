rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == "rangumallik@gmail.com";
    }

    // Singleton content docs: content/profile, content/hero, content/about, content/marquee
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collections editable from the admin panel
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skillGroups/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /socialLinks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
